{
  "servers": {
    "mcp-bridge": {
      "command": "mcp-bridge",
      "args": [
        "--config", "${HOME}/.cache/secrets/${USER}.mcpservers.json",
        "--port", "9741"
      ],
      "gracePeriod": "30m",
      "logFile": "${HOME}/Library/Logs/mcp-bridge.log",
      "skipIfEnv": "MCP_COMPANION_BRIDGE_URL"
    }
  }
}
