    "keywords": [
        "opencode",
        "opencode-plugin",
        "sharedserver",
        "process-manager",
        "plugin"
    ],
    "author": "George Harker <george@georgeharker.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/georgeharker/sharedserver.git",
        "directory": "plugins/opencode-sharedserver"
    },
    "bugs": {
        "url": "https://github.com/georgeharker/sharedserver/issues"
    },
    "homepage": "https://github.com/georgeharker/sharedserver/tree/main/plugins/opencode-sharedserver#readme",
    "publishConfig": {
        "access": "public"
    },
    "peerDependencies": {
        "@opencode-ai/plugin": ">=1.3.0"
    },
    "devDependencies": {
        "@opencode-ai/plugin": "^1.3.0",
        "@types/node": "^22.0.0",
        "typescript": "^5.6.0"
    },
    "engines": {
        "node": ">=18.0.0"
    }
