{
    "name": "@geohar/opencode-sharedserver",
    "version": "0.1.5",
    "description": "OpenCode plugin: manage shared backend processes via the sharedserver CLI.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run clean && npm run build"
